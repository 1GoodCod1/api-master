# Application
NODE_ENV=development
PORT=4000

# Admin seed credentials (defaults: admin@faber.md / admin123)
# ADMIN_EMAIL=admin@faber.md
# ADMIN_PASSWORD=admin123
# ADMIN_PHONE=+37360000000
# Timezone for Moldova (Europe/Chisinau). Set for local dev; Docker sets via compose.
TZ=Europe/Chisinau
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# --- TLS (Docker dev) — если Google OAuth падает с UNABLE_TO_VERIFY_LEAF_SIGNATURE ---
# Образ задаёт NODE_OPTIONS=--use-system-ca и SSL_CERT_FILE; при корп. SSL-инспекции:
# 1) Экспортируйте корневой PEM в docker/certs/extra-ca.pem и раскомментируйте:
# NODE_EXTRA_CA_CERTS=/app/docker/certs/extra-ca.pem
# 2) Крайний случай только локально (отключает проверку HTTPS для всего Node — опасно):
# NODE_TLS_REJECT_UNAUTHORIZED=0
# 3) Убедитесь, что HTTPS_PROXY/HTTP_PROXY не ломают выход к Google без вашего CA.

# Database (Docker) - match POSTGRES_* from docker-compose
DATABASE_URL="postgresql://user:password@postgres:5432/db"
# Optional: disable Prisma SQL event logging under load (default: on when NODE_ENV=development)
# PRISMA_LOG_QUERIES=false

# Redis (Docker)
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT & encryption - ROTATE BEFORE PRODUCTION! Run: npm run generate:secrets
JWT_ACCESS_SECRET=your-jwt-access-secret-min-32-chars
# Опционально в dev: если не задан, совпадает с JWT_ACCESS_SECRET. В production обязан быть и отличаться от access.
JWT_OAUTH_PENDING_SECRET=your-oauth-pending-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=3d
ID_ENCRYPTION_SECRET=your-encryption-secret-32-chars
ENCRYPTION_KEY=your-encryption-key-64-hex-chars

# Web Push (optional). Pair from: npm run generate:secrets — must match; then restart API container.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=admin@faber.md

# MIA / MAIB QR payments (optional)
MIA_CLIENT_ID=
MIA_CLIENT_SECRET=
MIA_BASE_URL=https://api.maib.md
MIA_AUTH_PATH=/v1/auth
MIA_CREATE_QR_PATH=/v1/qr/create
MIA_TERMINAL_ID=P011111
# Sandbox: set to true to allow POST /payments/mia-sandbox-simulate
MIA_SANDBOX=false
MIA_TEST_PAY_PATH=/v2/mia/test-pay

# Backblaze B2 (S3-compatible, production file storage)
# Create Application Key in B2 Console; bucket must allow public read if using public URLs
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=faber-md-uploads
B2_REGION=eu-central-003
# Optional: override endpoint (default https://s3.<B2_REGION>.backblazeb2.com)
# B2_ENDPOINT=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telegram (optional). For auto-connect: set webhook via
# GET https://api.telegram.org/bot<TOKEN>/setWebhook?url=...&secret_token=<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp (optional, uses Twilio WhatsApp API)
WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_SENDER_ID=whatsapp:+14155238886

# Email (optional)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_HTTP_PROVIDER_URL=
SMS_HTTP_PROVIDER_API_KEY=
SMS_HTTP_PROVIDER_API_ID=

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# Web Push (браузерные уведомления). Сгенерировать: npm run generate:secrets
VAPID_PUBLIC_KEY=secret
VAPID_PRIVATE_KEY=secret
VAPID_EMAIL=admin@faber.md
