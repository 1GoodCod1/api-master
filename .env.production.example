# =============================================================================
# PRODUCTION — шаблон переменных окружения
# =============================================================================
# Локальный Docker:
#   cp .env.production.example .env
#   # Заполните .env, затем: npm run docker:prod:up
#
# Dokploy: скопируйте переменные в Environment tab (Dokploy сохранит в .env)
#
# НЕ коммитьте .env в Git!
#
# Порты Postgres (5433), PgBouncer (6432), Prometheus (9091), Grafana (3002), Portainer (9443)
# по умолчанию привязаны к 127.0.0.1 — доступ только с localhost.
# Чтобы открыть снаружи (отладка, внешний мониторинг), раскомментируйте:
# PORT_POSTGRES=5433:5432
# PORT_PGBOUNCER=6432:6432
# PORT_PROMETHEUS=9091:9090
# PORT_GRAFANA=3002:3000
# PORT_PORTAINER=127.0.0.1:9443:9443
# =============================================================================

NODE_ENV=production
PORT=4000
API_URL=https://api.your-domain.com
FRONTEND_URL=https://your-domain.com

# Admin seed credentials — ОБЯЗАТЕЛЬНО задать перед первым запуском seed!
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
ADMIN_PHONE=+373XXXXXXXX

# Database — DATABASE_URL используется приложением (NestJS),
# POSTGRES_DB/USER/PASSWORD — docker-compose для создания БД.
# Внутри Docker-сети PgBouncer слушает 5432 (6432 — это маппинг на хост, см. PORT_PGBOUNCER).
# Реальные строки для api/worker задаёт docker-compose.prod.yml (pgbouncer:5432 / postgres:5432).
DATABASE_URL=postgresql://postgres:CHANGE_THIS_STRONG_PASSWORD@pgbouncer:5432/project3
# DATABASE_READ_URL=postgresql://postgres:CHANGE_THIS_STRONG_PASSWORD@postgres-read:5432/project3
POSTGRES_DB=project3
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis — dev: standalone (redis:6379), prod: Sentinel (docker-compose задаёт REDIS_SENTINELS)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Prod (Dokploy/docker-compose.prod): Sentinel — задаётся в environment api/worker
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_NAME=mymaster
# Пароль для самого Sentinel (редко). Bitnami обычно без пароля на 26379 — не задавайте REDIS_SENTINEL_PASSWORD

# JWT & encryption — ОБЯЗАТЕЛЬНО сгенерировать: npm run generate:secrets
JWT_ACCESS_SECRET=your-production-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=1h
ID_ENCRYPTION_SECRET=your-production-encryption-secret-32-chars
ENCRYPTION_KEY=your-production-encryption-key-64-hex-chars

# Auth & cookies
# USE_HTTPONLY_COOKIE=true
# REFRESH_COOKIE_NAME=rt
# REFRESH_COOKIE_MAX_AGE_DAYS=7
COOKIE_DOMAIN=.your-domain.com

# Security
# COOKIE_ORIGIN_CHECK=true (включено по умолчанию в production)
# REQUEST_TIMEOUT_MS=30000

# Rate limiting (по умолчанию в production используется Redis)
# RATE_LIMIT_WINDOW=900000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_REDIS_STORAGE=true

# HTTP audit (по умолчанию выкл. — большой объём и риск PII)
# AUDIT_HTTP_ENABLED=false

# MIA / MAIB QR payments (production)
MIA_CLIENT_ID=
MIA_CLIENT_SECRET=
MIA_BASE_URL=https://api.maib.md
MIA_SANDBOX=false
MIA_WEBHOOK_SECRET=
MIA_TERMINAL_ID=
# MIA_AUTH_PATH=/v1/auth
# MIA_CREATE_QR_PATH=/v1/qr/create
# MIA_TEST_PAY_PATH=/v2/mia/test-pay

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telegram. Webhook secret: задайте при setWebhook, проверяется в заголовке X-Telegram-Bot-Api-Secret-Token
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp
WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_SENDER_ID=whatsapp:+14155238886

# Email
EMAIL_ENABLED=true
EMAIL_FROM=noreply@your-domain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# B2 Storage
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=faber-md-uploads
B2_REGION=eu-central-003
B2_ENDPOINT=

# SMS
SMS_ENABLED=true
SMS_PROVIDER=twilio
# Альтернативный HTTP SMS-провайдер (вместо Twilio)
# SMS_HTTP_PROVIDER_URL=
# SMS_HTTP_PROVIDER_API_KEY=
# SMS_HTTP_PROVIDER_API_ID=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@faber.md
