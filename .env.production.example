# =============================================================================
# PRODUCTION — шаблон переменных окружения
# =============================================================================
# Локальный Docker:
#   cp .env.production.example .env
#   # Заполните .env, затем: npm run docker:prod:up
#
# Dokploy: скопируйте переменные в Environment tab (Dokploy сохранит в .env)
#
# НЕ коммитьте .env в Git!
# =============================================================================

NODE_ENV=production
PORT=4000
API_URL=https://api.your-domain.com
FRONTEND_URL=https://your-domain.com

# Database — значения подставляются в docker-compose.prod.yml
POSTGRES_DB=project3
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis (standalone or Sentinel — по умолчанию)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Redis Cluster (опционально): REDIS_CLUSTER=true + узлы кластера
# REDIS_CLUSTER=true
# REDIS_CLUSTER_NODES=node1.example.com:6379,node2.example.com:6379,node3.example.com:6379

# JWT & encryption — ОБЯЗАТЕЛЬНО сгенерировать: npm run generate:secrets
JWT_ACCESS_SECRET=your-production-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=1h
ID_ENCRYPTION_SECRET=your-production-encryption-secret-32-chars
ENCRYPTION_KEY=your-production-encryption-key-64-hex-chars

# MIA / MAIB QR payments (production)
MIA_CLIENT_ID=
MIA_CLIENT_SECRET=
MIA_BASE_URL=https://api.maib.md
MIA_SANDBOX=false
MIA_WEBHOOK_SECRET=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telegram. Webhook secret: задайте при setWebhook, проверяется в заголовке X-Telegram-Bot-Api-Secret-Token
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp
WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_SENDER_ID=whatsapp:+14155238886

# Email
EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# B2 Storage
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=master-hub-uploads
B2_REGION=eu-central-003

# SMS
SMS_ENABLED=true
SMS_PROVIDER=twilio

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@master-hub.md
