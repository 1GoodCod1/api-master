{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "setupFiles": ["<rootDir>/test/setup.ts"],
  "testEnvironment": "node",
  "testRegex": "test/unit/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "<rootDir>/src/**/*.ts",
    "!<rootDir>/src/main.ts",
    "!<rootDir>/src/**/*.module.ts",
    "!<rootDir>/src/**/*.dto.ts",
    "!<rootDir>/src/**/*.interface.ts"
  ],
  "coverageDirectory": "coverage",
  "coverageProvider": "v8"
}
