generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  MASTER
  ADMIN
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  PENDING_CLOSE
  CLOSED
  SPAM
}

enum FileType {
  AVATAR
  MASTER_PHOTOS
  OTHER
}

enum NotificationType {
  SMS
  TELEGRAM
  WHATSAPP
  EMAIL
  PUSH
  IN_APP
}

enum NotificationCategory {
  // Master notifications
  NEW_LEAD
  LEAD_STATUS_UPDATED
  NEW_REVIEW
  NEW_CHAT_MESSAGE
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED

  // Admin notifications
  ADMIN_NEW_VERIFICATION
  ADMIN_NEW_REPORT
  ADMIN_NEW_USER
  ADMIN_NEW_MASTER
  ADMIN_SYSTEM_ALERT
  ADMIN_NEW_LEAD
  ADMIN_NEW_REVIEW
  ADMIN_NEW_PAYMENT

  // Client notifications
  LEAD_SENT
  LEAD_CLOSE_REQUESTED
  MASTER_RESPONDED
  MASTER_AVAILABLE
  BOOKING_PENDING
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER

  // Promotions
  NEW_PROMOTION
  PROMOTION_STARTED

  // System
  SYSTEM_MAINTENANCE
  SYSTEM_UPDATE
}

enum LeadNotifyChannel {
  TELEGRAM
  WHATSAPP
  BOTH 
  NONE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
  READ
}

enum ReviewStatus {
  PENDING
  VISIBLE
  HIDDEN
  REPORTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TariffType {
  BASIC
  VIP
  PREMIUM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  REJECTED
}

enum ReportAction {
  BAN_CLIENT
  BAN_MASTER
  BAN_IP
  WARNING_CLIENT
  WARNING_MASTER
  NO_ACTION
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  EXPIRED
}

enum ConsentType {
  VERIFICATION_DATA_PROCESSING
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  MARKETING
  AGE_CONFIRMATION
}

model UserConsent {
  id          String      @id @default(uuid())
  userId      String
  consentType ConsentType
  granted     Boolean     @default(true)
  ipAddress   String?
  userAgent   String?
  version     String      @default("1.0")
  revokedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType])
  @@index([userId])
  @@index([consentType])
  @@index([createdAt])
  @@map("user_consents")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String    @unique
  password          String
  firstName         String?
  lastName          String?
  role              UserRole  @default(CLIENT)
  isVerified        Boolean   @default(false)
  isBanned          Boolean   @default(false)
  bannedAt          DateTime?
  bannedReason      String?
  avatarFileId      String?
  lastLoginAt       DateTime?
  phoneVerified     Boolean   @default(false)
  phoneVerifiedAt   DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  suspiciousScore   Int       @default(0)
  warningsCount     Int       @default(0)
  lastWarningAt     DateTime?
  ipAddress         String?
  deviceFingerprint String?
  preferredLanguage String?   @default("ro")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  masterProfile                   Master?
  avatarFile                      File?  @relation(fields: [avatarFileId], references: [id], onDelete: SetNull)
  auditLogs                       AuditLog[]
  notifications                   Notification[]
  refreshToken                    RefreshToken[]
  favorites                       Favorite[]
  reports                         Report[]
  reviews                         Review[]
  payments                        Payment[]
  passwordResetTokens             PasswordResetToken[]
  leads                           Lead[]
  bookings                        Booking[]
  clientPhotos                    ClientPhoto[]
  phoneVerifications              PhoneVerification[]
  loginHistory                    LoginHistory[]
  masterAvailabilitySubscriptions MasterAvailabilitySubscription[]
  conversations                   Conversation[] @relation("ClientConversations")
  reviewVotes                     ReviewVote[]
  pushSubscriptions               PushSubscription[]
  digestSubscription              DigestSubscription?
  referralCode                    ReferralCode? @relation("ReferralOwner")
  referredBy                      Referral? @relation("ReferredBy")
  emailDripStatuses               EmailDripStatus[]
  consents                        UserConsent[]

  @@index([avatarFileId])
  @@index([phoneVerified])
  @@index([twoFactorEnabled])
  @@index([suspiciousScore])
  @@index([ipAddress])
  @@index([role, isBanned, isVerified])
  @@map("users")
}

model Master {
  id                      String             @id @default(uuid())
  userId                  String             @unique
  slug                    String?            @unique
  description             String?
  services                Json?
  avatarFileId            String?
  rating                  Float              @default(0.0)
  totalReviews            Int                @default(0)
  experienceYears         Int                @default(0)
  cityId                  String
  categoryId              String
  tariffExpiresAt         DateTime?
  tariffCancelAtPeriodEnd Boolean            @default(false)
  pendingUpgradeTo        TariffType?
  pendingUpgradeCreatedAt DateTime?
  isFeatured              Boolean            @default(false)
  views                   Int                @default(0)
  leadsCount              Int                @default(0)
  extraPhotosCount        Int                @default(0)
  profileLastEditedAt     DateTime?
  pendingVerification     Boolean            @default(false)
  verificationSubmittedAt DateTime?
  lifetimePremium         Boolean            @default(false)
  isOnline                Boolean            @default(false)
  lastActivityAt          DateTime?
  isBusy                  Boolean            @default(false)
  maxLeadsPerDay          Int                @default(10)
  leadsReceivedToday      Int                @default(0)
  leadsResetAt            DateTime?
  availabilityStatus      AvailabilityStatus @default(AVAILABLE)
  maxActiveLeads          Int                @default(5)
  currentActiveLeads      Int                @default(0)
  telegramChatId          String?
  whatsappPhone           String?
  leadNotifyChannel       LeadNotifyChannel? @default(BOTH)
  notifyTariffSms         Boolean            @default(true)
  notifyTariffInApp       Boolean            @default(true)
  workStartHour           Int                @default(9)
  workEndHour             Int                @default(18)
  autoresponderEnabled    Boolean            @default(false)
  autoresponderMessage    String?
  slotDurationMinutes     Int                @default(60)
  latitude                Float?
  longitude               Float?
  googleCalendarId        String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt


  search_vector Unsupported("tsvector")?
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarFile   File?               @relation(fields: [avatarFileId], references: [id], onDelete: SetNull)
  city         City                @relation(fields: [cityId], references: [id])
  category     Category            @relation(fields: [categoryId], references: [id])
  tariffType   TariffType          @default(BASIC)
  verification MasterVerification?

  leads                     Lead[]
  photos                    MasterPhoto[]
  portfolio                 PortfolioItem[]
  reviews                   Review[]
  payments                  Payment[]
  analytics                 MasterAnalytics[]
  favorites                 Favorite[]
  bookings                  Booking[]
  reports                   Report[]
  availabilitySubscriptions MasterAvailabilitySubscription[]
  conversations             Conversation[]
  promotions                Promotion[]
  quickReplies              QuickReply[]
  telegramConnectTokens     TelegramConnectToken[]

  @@index([cityId])
  @@index([categoryId])
  @@index([rating])
  @@index([tariffType])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([categoryId, cityId, isFeatured, tariffType])
  @@index([categoryId, cityId, rating])
  @@index([tariffType, isFeatured, rating])
  @@index([categoryId, tariffType, isFeatured])
  @@index([isOnline, lastActivityAt])
  @@index([isBusy, isOnline])
  @@index([availabilityStatus, currentActiveLeads])
  @@map("masters")
}

model TelegramConnectToken {
  id        String   @id @default(uuid())
  token     String   @unique
  masterId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([masterId])
  @@index([expiresAt])
  @@map("telegram_connect_tokens")
}

model QuickReply {
  id        String   @id @default(uuid())
  masterId  String
  text      String   @db.VarChar(500)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([masterId])
  @@index([masterId, order])
  @@map("quick_replies")
}

model MasterPhoto {
  id        String   @id @default(uuid())
  masterId  String
  fileId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([masterId, fileId])
  @@index([masterId])
  @@index([fileId])
  @@index([order])
  @@index([createdAt])
  @@map("master_photos")
}

model PortfolioItem {
  id           String   @id @default(uuid())
  masterId     String
  title        String?
  description  String?
  beforeFileId String
  afterFileId  String
  serviceTags  String[] @default([])
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  master     Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  beforeFile File   @relation("PortfolioBefore", fields: [beforeFileId], references: [id], onDelete: Cascade)
  afterFile  File   @relation("PortfolioAfter", fields: [afterFileId], references: [id], onDelete: Cascade)

  @@index([masterId])
  @@index([masterId, order])
  @@index([createdAt])
  @@map("portfolio_items")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model MasterVerification {
  id                 String             @id @default(uuid())
  masterId           String             @unique
  status             VerificationStatus @default(PENDING)
  documentType       String
  documentNumber     String
  documentFrontId    String?
  documentBackId     String?
  selfieId           String?
  phone              String
  phoneVerified      Boolean            @default(false)
  notes              String?
  reviewedBy         String?
  reviewedAt         DateTime?
  submittedAt        DateTime           @default(now())
  documentsDeletedAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  master        Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  documentFront File? @relation("VerificationDocumentFront", fields: [documentFrontId], references: [id], onDelete: SetNull)
  documentBack  File? @relation("VerificationDocumentBack", fields: [documentBackId], references: [id], onDelete: SetNull)
  selfie        File? @relation("VerificationSelfie", fields: [selfieId], references: [id], onDelete: SetNull)

  @@index([masterId])
  @@index([status])
  @@index([submittedAt])
  @@map("master_verifications")
}

model ClientPhoto {
  id        String   @id @default(uuid())
  userId    String
  fileId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId])
  @@index([fileId])
  @@index([order])
  @@index([createdAt])
  @@map("client_photos")
}

model File {
  id           String   @id @default(uuid())
  filename     String
  path         String   @unique
  mimetype     String
  size         Int
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  masters              Master[]
  masterPhotos         MasterPhoto[]
  clientPhotos         ClientPhoto[]
  leadFiles            LeadFile[]
  reviewFiles          ReviewFile[]
  userAvatars          User[]
  verificationDocFront MasterVerification[] @relation("VerificationDocumentFront")
  verificationDocBack  MasterVerification[] @relation("VerificationDocumentBack")
  verificationSelfie   MasterVerification[] @relation("VerificationSelfie")
  messageFiles         MessageFile[]
  portfolioBefore      PortfolioItem[]      @relation("PortfolioBefore")
  portfolioAfter       PortfolioItem[]      @relation("PortfolioAfter")

  @@index([mimetype])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([size])
  @@map("files")
}

model Category {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  icon         String?
  iconKey      String?
  iconUrl      String?
  translations Json?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  masters Master[]

  @@map("categories")
}

model City {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  translations Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  masters Master[]

  @@map("cities")
}

model Lead {
  id          String     @id
  masterId    String
  clientPhone String
  clientName  String?
  clientId    String?
  message     String
  status      LeadStatus @default(NEW)
  spamScore   Int        @default(0)
  isPremium   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  master      Master     @relation(fields: [masterId], references: [id], onDelete: Cascade)
  client      User?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  files        LeadFile[]
  bookings     Booking[]
  reports      Report[]
  reviews      Review[]
  conversation Conversation?

  @@index([masterId])
  @@index([clientPhone])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([masterId, status, createdAt])
  @@index([clientId, status, createdAt])
  @@map("leads")
}

model LeadFile {
  id        String   @id @default(uuid())
  leadId    String
  fileId    String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([leadId, fileId])
  @@index([leadId])
  @@index([fileId])
  @@map("lead_files")
}

model Review {
  id             String           @id @default(uuid())
  masterId       String
  clientPhone    String
  clientName     String?
  clientId       String?
  leadId         String?          @unique
  rating         Int
  comment        String?
  status         ReviewStatus     @default(PENDING)
  moderatedBy    String?
  moderatedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  master         Master           @relation(fields: [masterId], references: [id], onDelete: Cascade)
  client         User?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead           Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)

  reviewCriteria ReviewCriteria[]
  reviewFiles    ReviewFile[]
  replies        ReviewReply[]
  votes          ReviewVote[]

  @@unique([masterId, clientPhone])
  @@unique([masterId, clientId])
  @@index([masterId])
  @@index([clientPhone])
  @@index([clientId])
  @@index([leadId])
  @@index([rating])
  @@index([status])
  @@index([createdAt])
  @@index([masterId, status, createdAt])
  @@index([masterId, rating, status])
  @@map("reviews")
}

model ReviewFile {
  id        String   @id @default(uuid())
  reviewId  String
  fileId    String
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([reviewId, fileId])
  @@index([reviewId])
  @@index([fileId])
  @@map("review_files")
}

model ReviewCriteria {
  id        String   @id @default(uuid())
  reviewId  String
  criteria  String 
  rating    Int
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, criteria])
  @@index([reviewId])
  @@index([criteria])
  @@map("review_criteria")
}

model Payment {
  id         String        @id @default(uuid())
  masterId   String
  userId     String
  amount     Decimal
  currency   String        @default("MDL")
  metadata   Json?
  paidAt     DateTime?
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  master     Master        @relation(fields: [masterId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffType TariffType
  status     PaymentStatus @default(PENDING)

  @@index([masterId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([masterId, status, createdAt])
  @@index([userId, status, createdAt])
  @@map("payments")
}

model MasterAnalytics {
  id           String   @id @default(uuid())
  masterId     String
  date         DateTime @default(now())
  leadsCount   Int      @default(0)
  viewsCount   Int      @default(0)
  reviewsCount Int      @default(0)
  rating       Float    @default(0.0)
  revenue      Decimal  @default(0)
  createdAt    DateTime @default(now())

  master       Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([masterId, date])
  @@index([masterId])
  @@index([date])
  @@index([date, masterId])
  @@map("master_analytics")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String  @id @default(uuid())
  userId    String?
  title     String?
  message   String
  type      NotificationType
  category  NotificationCategory?
  status    NotificationStatus    @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime   @default(now())

  user      User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, type, createdAt])
  @@index([userId, category, createdAt])
  @@map("notifications")
}

model SystemAnalytics {
  id           String   @id @default(uuid())
  date         DateTime @default(now())
  totalUsers   Int      @default(0)
  totalMasters Int      @default(0)
  totalLeads   Int      @default(0)
  totalReviews Int      @default(0)
  totalRevenue Decimal  @default(0)
  activeUsers  Int      @default(0)
  cpuUsage     Float    @default(0.0)
  memoryUsage  Float    @default(0.0)
  redisKeys    Int      @default(0)
  queueJobs    Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([date])
  @@index([date])
  @@map("system_analytics")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  masterId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([userId, masterId])
  @@index([userId])
  @@index([masterId])
  @@index([userId, createdAt])
  @@index([masterId, createdAt])
  @@map("favorites")
}

model MasterAvailabilitySubscription {
  id         String    @id @default(uuid())
  clientId   String
  masterId   String
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?

  client User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([clientId, masterId])
  @@index([clientId])
  @@index([masterId])
  @@index([masterId, notifiedAt])
  @@map("master_availability_subscriptions")
}

model Booking {
  id          String        @id @default(uuid())
  masterId    String
  leadId      String?
  clientPhone String
  clientName  String?
  clientId    String?
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  notes       String?
  serviceName String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  master      Master        @relation(fields: [masterId], references: [id], onDelete: Cascade)
  client      User?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  reminders BookingReminder[]

  @@index([masterId])
  @@index([leadId])
  @@index([clientPhone])
  @@index([clientId])
  @@index([startTime])
  @@index([status])
  @@index([createdAt])
  @@index([masterId, status, startTime])
  @@index([masterId, status, createdAt])
  @@index([masterId, startTime])
  @@index([masterId, startTime, endTime])
  @@index([clientId, status, createdAt])
  @@map("bookings")
}

model BookingReminder {
  id        String    @id @default(uuid())
  bookingId String
  type      String
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, type])
  @@index([bookingId])
  @@index([sentAt])
  @@index([type])
  @@map("booking_reminders")
}

model Report {
  id          String        @id @default(uuid())
  clientId    String
  masterId    String
  leadId      String?
  reason      String
  description String
  evidence    String?
  status      ReportStatus  @default(PENDING)
  action      ReportAction?
  reviewedBy  String?
  reviewedAt  DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  master      Master        @relation(fields: [masterId], references: [id], onDelete: Cascade)
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([masterId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

model PhoneVerification {
  id         String    @id @default(uuid())
  userId     String
  phone      String
  code       String
  expiresAt  DateTime
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@index([code])
  @@index([expiresAt])
  @@map("phone_verifications")
}

model LoginHistory {
  id                String   @id @default(uuid())
  userId            String
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  location          String?
  success           Boolean  @default(true)
  failReason        String?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_history")
}

model IpBlacklist {
  id        String    @id @default(uuid())
  ipAddress String    @unique
  reason    String
  blockedBy String?
  expiresAt DateTime?
  permanent Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([ipAddress])
  @@index([expiresAt])
  @@map("ip_blacklist")
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String?
  sessionId   String?
  action      String
  masterId    String?
  categoryId  String?
  cityId      String?
  searchQuery String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([action])
  @@index([masterId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("user_activities")
}

model Tariff {
  id          String     @id @default(uuid())
  name        String
  type        TariffType
  price       String
  amount      Decimal
  days        Int        @default(30)
  description String?
  features    Json
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([type])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@map("tariffs")
}

// ============================================
// CHAT MODELS
// ============================================

enum SenderType {
  CLIENT
  MASTER
}

model Conversation {
  id            String    @id @default(uuid())
  leadId        String    @unique
  masterId      String
  clientId      String?
  clientPhone   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  closedAt      DateTime?

  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  master        Master    @relation(fields: [masterId], references: [id], onDelete: Cascade)
  client        User?     @relation("ClientConversations", fields: [clientId], references: [id], onDelete: SetNull)

  messages      Message[]

  @@index([masterId])
  @@index([clientId])
  @@index([leadId])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([masterId, lastMessageAt])
  @@index([clientId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid())
  conversationId  String
  senderId        String
  senderType      SenderType
  content         String        @db.VarChar(2000)
  isAutoresponder Boolean       @default(false)
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  files           MessageFile[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@index([readAt])
  @@map("messages")
}

model MessageFile {
  id        String   @id @default(uuid())
  messageId String
  fileId    String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([messageId, fileId])
  @@index([messageId])
  @@index([fileId])
  @@map("message_files")
}

// ============================================
// PROMOTION MODELS
// ============================================

model Promotion {
  id           String   @id @default(uuid())
  masterId     String
  title        String
  description  String
  discount     Int 
  serviceTitle String? 
  validFrom    DateTime
  validUntil   DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  master       Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([masterId])
  @@index([isActive])
  @@index([validFrom, validUntil])
  @@index([masterId, isActive, validUntil])
  @@map("promotions")
}

// ============================================
// REVIEW REPLY & VOTE MODELS
// ============================================

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String   @unique
  masterId  String
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([masterId])
  @@map("review_replies")
}

model ReviewVote {
  id        String   @id @default(uuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_votes")
}

// ============================================
// WEB PUSH SUBSCRIPTIONS
// ============================================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("push_subscriptions")
}

// ============================================
// DIGEST SUBSCRIPTION (auth-only, role-based)
// ============================================

model DigestSubscription {
  id           String   @id @default(uuid())
  userId       String   @unique
  subscribedAt DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("digest_subscriptions")
}

// ============================================
// APP SETTINGS (admin-toggleable features)
// ============================================

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ============================================
// EMAIL TEMPLATE OVERRIDES (admin-editable)
// ============================================

model EmailTemplateOverride {
  id         String   @id @default(uuid())
  templateId String
  lang       String
  subject    String?
  bodyHtml   String?
  updatedAt  DateTime @updatedAt

  @@unique([templateId, lang])
  @@map("email_template_overrides")
}

// ============================================
// REFERRAL PROGRAM
// ============================================

model ReferralCode {
  id         String   @id @default(uuid())
  userId     String   @unique
  code       String   @unique
  usageCount Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation("ReferralOwner", fields: [userId], references: [id], onDelete: Cascade)

  referrals Referral[]

  @@index([code])
  @@index([userId])
  @@map("referral_codes")
}

model Referral {
  id              String         @id @default(uuid())
  referralCodeId  String
  referredUserId  String         @unique
  rewardGranted   Boolean        @default(false)
  rewardGrantedAt DateTime?
  createdAt       DateTime       @default(now())

  status          ReferralStatus @default(PENDING)
  referralCode    ReferralCode   @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUser    User           @relation("ReferredBy", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referralCodeId])
  @@index([referredUserId])
  @@index([status])
  @@map("referrals")
}

// ============================================
// EMAIL DRIP CAMPAIGNS
// ============================================

model EmailDripStatus {
  id         String    @id @default(uuid())
  userId     String
  chainType  String
  step       Int       @default(0)
  status     String    @default("ACTIVE")
  metadata   Json?
  nextSendAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chainType])
  @@index([userId])
  @@index([status, nextSendAt])
  @@map("email_drip_statuses")
}
