{
  "name": "faber-md-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "nest build",
    "build:worker": "nest build worker",
    "build:bull-board": "nest build bull-board",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:worker": "node dist/processes/worker/worker.js",
    "start:worker:dev": "node --trace-deprecation -r ts-node/register -r tsconfig-paths/register src/processes/worker/worker.ts",
    "start:bull-board": "node dist/processes/bull-board/bull-board.js",
    "start:bull-board:dev": "node --trace-deprecation -r ts-node/register -r tsconfig-paths/register src/processes/bull-board/bull-board.ts",
    "start:debug": "node --trace-deprecation ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest-unit.json",
    "test:watch": "jest --config ./test/jest-unit.json --watch",
    "test:cov": "jest --config ./test/jest-unit.json --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:debug": "jest --config ./test/jest-e2e.json --detectOpenHandles",
    "test:api": "jest --config ./test/jest-e2e.json test/api",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "ts-node prisma/seed.ts",
    "seed:dev": "ts-node prisma/seed-dev.ts",
    "seed:prod": "ts-node prisma/seed-prod.ts",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f api",
    "docker:dev:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker-compose -f .docker-compose.dev.yml logs -f",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:rebuild": "docker compose -f docker-compose.prod.yml up -d --build --force-recreate",
    "docker:prune": "npm run docker:prune:dev && npm run docker:prune:prod",
    "docker:prune:dev": "docker-compose -f docker-compose.dev.yml down -v --remove-orphans --rmi local",
    "docker:prune:prod": "docker compose -f docker-compose.prod.yml down -v --remove-orphans --rmi local",
    "docker:seed": "docker exec fabermd-api-dev npm run seed",
    "docker:seed:prod": "docker exec fabermd-api-prod npm run seed:prod",
    "docker:migrate": "docker exec fabermd-api-dev npx prisma migrate deploy",
    "docker:generate": "docker exec fabermd-api-dev npx prisma generate",
    "docker:migrate:reset": "docker exec fabermd-api-dev npx prisma migrate reset --force",
    "docker:migrate:dev": "docker exec fabermd-api-dev npx prisma migrate deploy",
    "docker:migrate:create": "docker exec -it fabermd-api-dev npx prisma migrate dev",
    "docker:migrate:prod": "docker exec fabermd-api-prod npx prisma migrate deploy",
    "redis:commander": "docker-compose -f docker-compose.dev.yml up -d redis-commander",
    "docker:studio": "docker-compose -f docker-compose.dev.yml up -d prisma-studio",
    "docker:studio:logs": "docker-compose -f docker-compose.dev.yml logs -f prisma-studio",
    "redis:cli": "docker exec -it fabermd-redis redis-cli",
    "redis:ping": "docker exec -it fabermd-redis redis-cli ping",
    "redis:keys": "docker exec fabermd-redis redis-cli KEYS \"cache:*\"",
    "redis:flush": "docker exec fabermd-redis redis-cli FLUSHDB",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "generate:secrets": "node scripts/generate-secrets.js",
    "update:deps": "npx npm-check-updates -u",
    "update:deps:check": "npx npm-check-updates",
    "local:recreate:db": "npm run prisma:reset && npm run prisma:migrate && npm run prisma:generate && npm run seed",
    "docker:dev:create": "npm run docker:dev:build && npm run docker:dev:up && npm run docker:migrate:reset && npm run docker:migrate:dev && npm run docker:generate && npm run docker:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/extension-read-replicas": "^0.5.0",
    "@types/multer": "^2.1.0",
    "@willsoto/nestjs-prometheus": "6.1.0",
    "argon2": "^0.44.0",
    "axios": "^1.14.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.2",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "lodash": "^4.17.23",
    "minimatch": "^10.2.4",
    "path-to-regexp": "^8.4.1",
    "test-exclude": {
      "minimatch": "^5.1.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
