{
  "name": "mdmaster",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest-unit.json",
    "test:watch": "jest --config ./test/jest-unit.json --watch",
    "test:cov": "jest --config ./test/jest-unit.json --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:api": "jest --config ./test/jest-e2e.json test/api",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "ts-node prisma/seed.ts",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f api",
    "docker:dev:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker-compose -f .docker-compose.dev.yml logs -f",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml build --no-cache",
    "docker:prod:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:prod:rebuild": "docker-compose -f docker-compose.prod.yml up -d --build --force-recreate",
    "docker:seed": "docker exec masterhub-api-dev npm run seed",
    "docker:seed:prod": "docker exec masterhub-api-prod npm run seed",
    "docker:migrate": "docker exec masterhub-api-dev npx prisma migrate deploy",
    "docker:generate": "docker exec masterhub-api-dev npx prisma generate",
    "docker:migrate:reset": "docker exec masterhub-api-dev npx prisma migrate reset --force",
    "docker:migrate:dev": "docker exec masterhub-api-dev npx prisma migrate deploy",
    "docker:migrate:create": "docker exec -it masterhub-api-dev npx prisma migrate dev",
    "docker:migrate:prod": "docker exec masterhub-api-prod npx prisma migrate deploy",
    "redis:commander": "docker-compose -f docker-compose.dev.yml up -d redis-commander",
    "docker:studio": "docker-compose -f docker-compose.dev.yml up -d prisma-studio",
    "docker:studio:logs": "docker-compose -f docker-compose.dev.yml logs -f prisma-studio",
    "redis:cli": "docker exec -it masterhub-redis redis-cli",
    "redis:keys": "docker exec masterhub-redis redis-cli KEYS \"cache:*\"",
    "redis:flush": "docker exec masterhub-redis redis-cli FLUSHDB",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "generate:secrets": "node scripts/generate-secrets.js",
    "local:recreate:db": "npm run prisma:reset && npm run prisma:migrate && npm run prisma:generate && npm run seed",
    "docker:dev:recreate": "npm run docker:dev:up && npm run docker:migrate:reset && npm run docker:migrate:dev && npm run docker:generate && npm run docker:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.13",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.4.1",
    "@types/leaflet": "^1.9.21",
    "@types/multer": "^2.0.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "ejs": "^4.0.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "hono": "^4.11.8",
    "ioredis": "^5.9.2",
    "lodash": "^4.17.23",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.12.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.17.4",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "prisma": "^7.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "lodash": "^4.17.23",
    "minimatch": "^10.2.1",
    "test-exclude": {
      "minimatch": "^5.1.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
